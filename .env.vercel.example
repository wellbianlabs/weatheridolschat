# ============================================================================
# Vercel 환경 변수 — 복붙용 (Import .env File)
# ============================================================================
# 사용: 이 파일 전체 내용을 복사 → Vercel Settings → Environment Variables
#       → "Import .env File" 클릭 → 붙여넣기.
# 자세한 설명: docs/DEPLOY_VERCEL_ENV.md
# ============================================================================


# ── Phase 1 — 즉시 배포 (Mock 모드) ─────────────────────────────────────────
NODE_ENV=production
MOCK_MODE=true
NEXT_PUBLIC_APP_URL=https://weatheridolschat.vercel.app


# ── Phase 2 — Supabase (선택) ───────────────────────────────────────────────
# 발급: https://supabase.com/dashboard/project/<ref>/settings/api
# NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECTREF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PASTE_ANON_KEY_HERE
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PASTE_SERVICE_ROLE_HERE


# ── Phase 3 — 실제 AI (선택, 활성화 시 MOCK_MODE=false로 변경) ──────────────
# Anthropic Claude: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-PASTE_HERE

# Google Gemini (무료 티어 있음): https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIzaPASTE_HERE

# OpenAI (이미지 생성): https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-PASTE_HERE

# Suno (음악 생성): https://sunoapi.org → dashboard → API Keys
# SUNO_API_KEY=PASTE_HERE
# SUNO_API_BASE=https://api.sunoapi.org   (다른 Suno-호환 제공자 쓸 때만)


# ── Phase 4 — 실시간 날씨 (선택) ────────────────────────────────────────────
# KMA 기상청 (대한민국 무료): https://www.data.go.kr → "단기예보조회서비스" 검색 → 활용신청
# 발급 후 "일반 인증키(Decoding)" 값을 그대로 붙여넣기
# KWEATHER_API_KEY=PASTE_DECODED_SERVICE_KEY

# OpenWeatherMap (글로벌 fallback, 무료 60/min): https://home.openweathermap.org/api_keys
# OPENWEATHERMAP_API_KEY=PASTE_32_HEX_CHARS_HERE


# ── Phase 5 — 제휴/광고 (Phase 2 사업 단계) ─────────────────────────────────
# NASMEDIA_API_KEY=
