# =============================================================================
# Weather Idols Chat — Environment Variables
# Copy this file to .env.local at the repo root and fill in real values.
# =============================================================================

# Global ---------------------------------------------------------------------
NODE_ENV=development

# MOCK_MODE controls whether real APIs are called.
#   true  (default) → all adapters return mock responses, no key required
#   false           → use real keys below; missing key falls back to mock
MOCK_MODE=true

# -- Supabase (Phase 2) ------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -- AI Providers (used when MOCK_MODE=false) --------------------------------
# Anthropic Claude — premium tier chat model (claude-sonnet-4-6).
ANTHROPIC_API_KEY=

# Google Gemini — free tier chat model (gemini-1.5-flash-latest).
GEMINI_API_KEY=

# OpenAI — image generation (gpt-image-1 / dall-e-3).
OPENAI_API_KEY=

# Suno music generation (sunoapi.org-compatible REST API).
# https://sunoapi.org — get key at dashboard after signup.
SUNO_API_KEY=
# Override only if you use a different Suno-compatible provider
# SUNO_API_BASE=https://api.sunoapi.org

# -- Weather Providers -------------------------------------------------------
# KMA 기상청 단기예보 (data.go.kr public API). Korea-only, free 1M/month.
# Get at https://www.data.go.kr → search "단기예보조회서비스" → apply.
KWEATHER_API_KEY=

# OpenWeatherMap — global fallback for non-KR coords (free 60/min, 1M/month).
# https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# -- Affiliate (Phase 2) -----------------------------------------------------
NASMEDIA_API_KEY=

# -- App URLs ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Mobile ------------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
