# =============================================================================
# Weather Idols Chat — Environment Variables
# Copy this file to .env.local at the repo root and fill in real values.
# =============================================================================

# Global ---------------------------------------------------------------------
NODE_ENV=development

# MOCK_MODE controls whether real APIs are called.
#   true  (default) → all adapters return mock responses, no key required
#   false           → use real keys below; missing key falls back to mock
MOCK_MODE=true

# -- Supabase (Auth + DB) ----------------------------------------------------
# Both PUBLIC vars must be set for /login to render the email form.
# Without them the site runs anonymously and every API route falls back
# to the old behaviour (no per-user quota / no admin bypass).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated admin emails that bypass every quota / billing gate.
# Default: admin@wellbianlabs.io. Add more like:
#   ADMIN_EMAILS=admin@wellbianlabs.io,founder@example.com
ADMIN_EMAILS=admin@wellbianlabs.io

# -- AI Providers (used when MOCK_MODE=false) --------------------------------
# Anthropic Claude — premium tier chat model (claude-sonnet-4-6).
ANTHROPIC_API_KEY=

# Google Gemini — free tier chat model (gemini-1.5-flash-latest).
GEMINI_API_KEY=

# OpenAI — image generation (gpt-image-1 / dall-e-3).
OPENAI_API_KEY=

# Google Cloud Text-to-Speech — voice playback ("🔊 음성 듣기" + MP3 download).
# Get at console.cloud.google.com → APIs & Services → Library →
# "Cloud Text-to-Speech API" → Enable → Credentials → Create API key.
# Restrict the key to the Text-to-Speech API for safety.
GOOGLE_TTS_API_KEY=

# Suno music generation (sunoapi.org-compatible REST API).
# https://sunoapi.org — get key at dashboard after signup.
SUNO_API_KEY=
# Override only if you use a different Suno-compatible provider
# SUNO_API_BASE=https://api.sunoapi.org
# sunoapi.org REQUIRES a callBackUrl on /api/v1/generate even though we
# poll for status. Default placeholder works; set this to a real webhook
# if you want to receive completion notifications.
# SUNO_CALLBACK_URL=https://your-app.vercel.app/api/suno-callback

# -- Weather Providers -------------------------------------------------------
# KWeather B2B gateway (gateway.kweather.co.kr:8443). Korea, 읍면동(동) 단위 실황.
# Contract key from KWeather Co. — paste the raw key value. Auth via ?api_key=.
# Cascade: kw-odam1 (읍면동) → kw-odam2 (시군구) → kw-odam3 (광역) → Open-Meteo.
KW_API_KEY=
# Legacy alias — only set this if you can't rename in Vercel yet.
# KWEATHER_API_KEY=

# OpenWeatherMap — optional global provider when no KW key (free 60/min, 1M/mo).
# https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# Open-Meteo (no key, worldwide) is the *final* fallback. Always on.

# -- Affiliate (Phase 2) -----------------------------------------------------
NASMEDIA_API_KEY=

# -- App URLs ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Mobile ------------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
