{
  "name": "weatheridolschat",
  "version": "0.0.0",
  "private": true,
  "description": "Weather Idols Chat - K-weather x AI multimodal lifestyle companion",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@wi/web",
    "dev:mobile": "turbo run dev --filter=@wi/mobile",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.5.4",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "18.3.1",
        "react-dom": "18.3.1"
      }
    }
  }
}
